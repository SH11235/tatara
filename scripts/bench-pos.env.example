# bench-pos.sh の machine 依存設定テンプレート。
#
# このファイルを scripts/bench-pos.env にコピーし、自分の環境の path を書く。
# scripts/bench-pos.env は .gitignore 済 (リポジトリに焼かれない)。bench-pos.sh
# が起動時に source する。
#
# `: "${VAR:=...}"` 形式なので、bench-pos.sh 実行時に明示的に前置きした env var
# (例 `DATA=/other/path scripts/bench-pos.sh`) はこのファイルの値より優先される。

# PSV データファイル
: "${DATA:=/path/to/PSV}"
# progress 係数ファイル (ARCH=layerstack 時のみ必須)
: "${PROG:=/path/to/progress.bin}"

# 任意: run 回数や GPU clock lock 等もここで固定できる
# : "${RUNS:=5}"
# : "${BENCH_LOCK_CLOCK:=1}"

# 任意: 計測対象アーキ (default layerstack、ARCH=simple で Simple 4 層)
# : "${ARCH:=simple}"
# : "${SIMPLE_ARCH:=512x2-8-64}"
# : "${SIMPLE_ACTIVATION:=crelu}"

# 任意: dataloader prefetch worker 数 (default 16、CPU spec に応じて 24-32 等に調整可)
# : "${THREADS:=16}"
